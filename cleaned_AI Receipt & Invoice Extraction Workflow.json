        "jsCode": "// Extract OCR text safely from YOUR actual structure\n\nlet extractedText = '';\n\nfor (const item of $input.all()) {\n\n  try {\n\n    const text =\n      item.json.responses?.[0]?.responses?.[0]?.fullTextAnnotation?.text || '';\n\n    extractedText += '\\n\\n' + text;\n\n  } catch (error) {\n\n    console.log('OCR extraction error:', error);\n  }\n}\n\nreturn [\n  {\n    json: {\n      extracted_text: extractedText.trim()\n    }\n  }\n];"
      },
