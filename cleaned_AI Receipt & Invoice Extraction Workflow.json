        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"date\": {\n      \"type\": \"string\",\n      \"description\": \"Extract the transaction or payment date from the receipt in YYYY-MM-DD format.\"\n    },\n    \"receiptId\": {\n      \"type\": \"string\",\n      \"description\": \"Extract the receipt number, invoice number, or transaction reference ID.\"\n    },\n    \"vendor\": {\n      \"type\": \"string\",\n      \"description\": \"Extract the business, company, or merchant name from the receipt.\"\n    },\n    \"description\": {\n      \"type\": \"string\",\n      \"description\": \"Extract a short description of the purchased item, service, or payment purpose.\"\n    },\n    \"amount\": {\n      \"type\": \"number\",\n      \"description\": \"Extract the final total amount paid from the receipt.\"\n    },\n    \"currency\": {\n      \"type\": \"string\",\n      \"description\": \"Extract the currency used in the receipt such as INR, USD, CAD, EUR.\"\n    },\n    \"category\": {\n      \"type\": \"string\",\n      \"description\": \"Classify the expense category such as Education, Travel, Food, Software, Office Supplies, Marketing, etc.\"\n    },\n    \"expenseType\": {\n      \"type\": \"string\",\n      \"description\": \"Extract the specific expense type or purchase type.\"\n    },\n    \"paymentMethod\": {\n      \"type\": \"string\",\n      \"description\": \"Extract the payment method if available such as Credit Card, Debit Card, UPI, Cash, PayPal, etc.\"\n    },\n    \"gstHstPaid\": {\n      \"type\": \"number\",\n      \"description\": \"Extract the GST or HST tax amount if available. Return 0 if not present.\"\n    },\n    \"pstPaid\": {\n      \"type\": \"number\",\n      \"description\": \"Extract the PST or provincial tax amount if available. Return 0 if not present.\"\n    },\n    \"totalTax\": {\n      \"type\": \"number\",\n      \"description\": \"Extract the total combined tax amount from the receipt. Return 0 if not present.\"\n    }\n  },\n  \"required\": [\n    \"date\",\n    \"receiptId\",\n    \"vendor\",\n    \"description\",\n    \"amount\",\n    \"currency\",\n    \"category\",\n    \"expenseType\",\n    \"paymentMethod\",\n    \"gstHstPaid\",\n    \"pstPaid\",\n    \"totalTax\"\n  ]\n}",
